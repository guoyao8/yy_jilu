# ===== 腾讯云 ASR（语音识别）=====
TENCENT_ASR_APP_ID=
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=
TENCENT_ASR_ENGINE=16k_zh

# ===== 腾讯云 CloudBase（生产数据库）=====
# Vercel 部署时必须配置以下三项环境变量
CLOUDBASE_ENV_ID=
CLOUDBASE_SECRET_ID=
CLOUDBASE_SECRET_KEY=

# ===== 本地开发可选 =====
# 设为 "1" 后改用 src/server/local-db.ts 提供的 JSON 文件存储，无需连云
USE_LOCAL_DB=
# 本地 JSON 存储文件路径（默认 data/local-db.json）
LOCAL_DB_PATH=
# 历史 SQLite 数据迁移脚本使用
SQLITE_DB_PATH=
